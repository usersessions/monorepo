{
  "name": "extension",
  "displayName": "usersessions",
  "version": "0.1.0",
  "description": "Get your product found — assisted distribution across the platforms AI assistants and humans discover software from.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@usersessions/shared": "workspace:*",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/react": "18.2.37",
    "@types/react-dom": "18.2.15",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": ["activeTab", "scripting", "tabs", "storage", "alarms"],
    "externally_connectable": {
      "matches": ["https://beta.usersessions.io/*", "http://localhost:3000/*"]
    }
  }
}
