# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Emails (Resend)
RESEND_API_KEY=
RESEND_FROM="usersessions <notifications@usersessions.io>"

# AI — Google AI Studio API key (starts with AIza)
GEMINI_API_KEY=

# Billing (Paystack) — M11. Plan codes come from Plans created in the Paystack dashboard.
# GATE: confirm settlement currency approval before enabling the billing flag.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_PLAN_FOUNDER_MONTHLY=
PAYSTACK_PLAN_FOUNDER_ANNUAL=
PAYSTACK_PLAN_AGENCY_MONTHLY=

# Crons (M9+) — shared secret checked by /api/cron/* routes
CRON_SECRET=

# Extension bridge — OPTIONAL: the token also flows via the token-bridge content script,
# which needs no extension ID.
NEXT_PUBLIC_EXTENSION_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://usersessions.io
